{
  "files.watcherExclude": {
    "**/builds/**": true,
    "**/references/**": true
  },
  "search.exclude": {
    "**/builds/**": true,
    "**/references/**": true
  },
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.outDir": "%DIR%/builds",
  "latex-workshop.latex.auxDir": "%DIR%/builds",
  "latex-workshop.latex.external.build.command": "./scripts/build-tex.sh",
  "latex-workshop.latex.external.build.args": [
    "%DOC_EXT%"
  ],
  "latex-workshop.view.pdf.viewer": "tab"
}
